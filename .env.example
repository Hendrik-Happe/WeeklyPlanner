DATABASE_URL="file:./dev.db"
# AUTH_SECRET wird automatisch von setup.sh generiert
AUTH_SECRET=

# Login-Rate-Limit (Credentials)
AUTH_RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_WINDOW_SECONDS=300
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5
AUTH_RATE_LIMIT_BLOCK_SECONDS=900
AUTH_TRUST_PROXY_HEADERS=false

# Passwort-Policy
AUTH_PASSWORD_MIN_LENGTH=6

# Optional für nicht-interaktives Setup (werden nicht dauerhaft benötigt)
# SEED_ADMIN_USERNAME="admin"
# SEED_ADMIN_PASSWORD="ein-sicheres-passwort"

# Branding / PWA
NEXT_PUBLIC_APP_NAME="WeeklyPlaner"
NEXT_PUBLIC_APP_SHORT_NAME="WeeklyPlaner"
NEXT_PUBLIC_APP_DESCRIPTION="Familien-Wochenplaner"
NEXT_PUBLIC_APP_THEME_COLOR="#3b82f6"
NEXT_PUBLIC_APP_BACKGROUND_COLOR="#f9fafb"
NEXT_PUBLIC_APP_START_URL="/day"

# App-Icon (Text + Farben)
NEXT_PUBLIC_APP_ICON_TEXT="W"
NEXT_PUBLIC_APP_ICON_BG_START="#2563eb"
NEXT_PUBLIC_APP_ICON_BG_END="#1d4ed8"
NEXT_PUBLIC_APP_ICON_ACCENT="#3b82f6"
NEXT_PUBLIC_APP_ICON_ACCENT_SOFT="#93c5fd"
NEXT_PUBLIC_APP_ICON_PANEL="#ffffff"
NEXT_PUBLIC_APP_ICON_PANEL_SOFT="#bfdbfe"

# Rechtliches (optional)
NEXT_PUBLIC_ENABLE_LEGAL_PAGES=false
NEXT_PUBLIC_LEGAL_OWNER_NAME=""
NEXT_PUBLIC_LEGAL_STREET=""
NEXT_PUBLIC_LEGAL_POSTAL_CODE=""
NEXT_PUBLIC_LEGAL_CITY=""
NEXT_PUBLIC_LEGAL_EMAIL=""

# Nextcloud OAuth (optional, fuer Kalender-Sync ohne gespeichertes Nextcloud-Passwort)
# Diese Werte bekommst du aus der OAuth2-Client-Konfiguration in Nextcloud.
# Optional: Wenn gesetzt, reicht in der App ein Klick auf "Mit Nextcloud verbinden".
NEXTCLOUD_SERVER_URL=""
# Optional: Standard-iCal-Feed fuer alle Nutzer. Wird nach OAuth-Connect automatisch uebernommen.
NEXTCLOUD_DEFAULT_ICS_URL=""
# Optional: Standard-Kalender-Slug fuer die automatische URL-Generierung (normalerweise 'personal').
NEXTCLOUD_DEFAULT_CALENDAR_SLUG="personal"
# Redirect URL in Nextcloud (Produktion): https://DEINE-DOMAIN/api/nextcloud/oauth/callback
# Redirect URL in Nextcloud (Lokal):      http://localhost:3000/api/nextcloud/oauth/callback
# Wichtig: Die Redirect-URL muss exakt zur aufgerufenen App-URL passen.
NEXTCLOUD_OAUTH_CLIENT_ID=""
NEXTCLOUD_OAUTH_CLIENT_SECRET=""