generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  passwordHash String @map("pinHash")
  role      Role     @default(USER)
  sessionVersion Int  @default(0)
  shoppingView String @default("LIST") // LIST | GRID
  createdAt DateTime @default(now())

  createdTasks       Task[]           @relation("CreatedBy")
  assignedTasks      Task[]           @relation("AssignedTo")
  assignedByMe       Task[]           @relation("AssignedBy")
  completions        TaskCompletion[]
  assignments        TaskAssignment[]
  assignedByMeOnDate TaskAssignment[] @relation("AssignedByOnDate")
  createdRecipes     Recipe[]         @relation("RecipeCreatedBy")
  assignedMealPlans  MealPlan[]       @relation("MealPlanAssignedBy")
  createdShoppingItems ShoppingItem[] @relation("ShoppingItemCreatedBy")
  createdShoppingLists ShoppingList[] @relation("ShoppingListCreatedBy")
  shoppingListMemberships ShoppingListMember[]
}

model AuthRateLimit {
  key            String   @id
  attempts       Int      @default(0)
  firstAttemptAt DateTime
  blockedUntil   DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ShoppingList {
  id              String   @id @default(cuid())
  name            String
  nameNormalized  String
  isSharedWithAll Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  createdById String
  createdBy   User @relation("ShoppingListCreatedBy", fields: [createdById], references: [id])

  members    ShoppingListMember[]
  items      ShoppingItem[]
  tagHistory ShoppingTagHistory[]

  @@index([nameNormalized])
}

model ShoppingListMember {
  id        String   @id @default(cuid())
  listId    String
  list      ShoppingList @relation(fields: [listId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([listId, userId])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  isPrivate   Boolean   @default(false)
  createdAt   DateTime  @default(now())

  createdById  String
  createdBy    User   @relation("CreatedBy", fields: [createdById], references: [id])

  assignedToId String?
  assignedTo   User?  @relation("AssignedTo", fields: [assignedToId], references: [id])

  assignedById String? // Wer die Zuweisung vorgenommen hat
  assignedBy   User?  @relation("AssignedBy", fields: [assignedById], references: [id])

  recurrence  RecurrenceRule?
  completions TaskCompletion[]
  assignments TaskAssignment[]
}

// Datumsspezifische Zuweisung (überschreibt Task.assignedToId für dieses Datum)
model TaskAssignment {
  id     String @id @default(cuid())
  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  date   String // ISO-Datum: "2026-04-20"
  userId String
  user   User   @relation(fields: [userId], references: [id])
  assignedById String? // Wer die Zuweisung vorgenommen hat
  assignedBy   User?  @relation("AssignedByOnDate", fields: [assignedById], references: [id])

  @@unique([taskId, date])
}

model RecurrenceRule {
  id     String @id @default(cuid())
  taskId String @unique
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  // ONCE | DAILY | WEEKLY | MONTHLY
  type      String
  interval  Int     @default(1)
  weekdays  String? // JSON-Array: [1,3] = Mo,Mi (0=So,1=Mo,...,6=Sa)
  monthFrom Int?    // 1–12 (inkl.)
  monthTo   Int?    // 1–12 (inkl.)
  validFrom  DateTime?
  validUntil DateTime?
}

model TaskCompletion {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  date      String   // ISO-Datum: "2026-04-20"
  status    String   // DONE | SNOOZED
  snoozedTo String?  // ISO-Datum falls verschoben
  createdAt DateTime @default(now())

  @@unique([taskId, date])
}

model Recipe {
  id          String   @id @default(cuid())
  title       String
  description String?
  sourceType  String   // APP | BOOK | LINK
  sourceText  String?
  url         String?
  createdAt   DateTime @default(now())

  createdById String
  createdBy   User     @relation("RecipeCreatedBy", fields: [createdById], references: [id])

  mealPlans MealPlan[]
}

model MealPlan {
  id        String   @id @default(cuid())
  date      String   // ISO-Datum: "2026-04-21"
  createdAt DateTime @default(now())

  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  assignedById String
  assignedBy   User   @relation("MealPlanAssignedBy", fields: [assignedById], references: [id])

  @@unique([date, recipeId])
}

model ShoppingItem {
  id             String   @id @default(cuid())
  name           String
  nameNormalized String
  removedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  createdById String
  createdBy   User @relation("ShoppingItemCreatedBy", fields: [createdById], references: [id])

  listId String?
  list   ShoppingList? @relation(fields: [listId], references: [id], onDelete: Cascade)

  tags ShoppingItemTag[]

  @@index([listId])
  @@index([nameNormalized])
}

model ShoppingItemTag {
  id              String @id @default(cuid())
  itemId          String
  item            ShoppingItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  value           String
  valueNormalized String

  @@unique([itemId, valueNormalized])
}

model ShoppingTagHistory {
  id                 String   @id @default(cuid())
  listId             String?
  list               ShoppingList? @relation(fields: [listId], references: [id], onDelete: Cascade)
  itemNameNormalized String
  value              String
  valueNormalized    String
  createdAt          DateTime @default(now())

  @@index([listId])
  @@unique([listId, itemNameNormalized, valueNormalized])
}
